# Open4Printing — sample environment variables.
# Copy non-secret defaults as needed; set real values in Replit Secrets.

# --- Required ---
DATABASE_URL=postgres://user:password@host:5432/dbname
SESSION_SECRET=change-me-to-a-long-random-string

# --- Default admin login (used by the one-time seed) ---
ADMIN_EMAIL=admin@open4printing.com
ADMIN_PASSWORD=admin123

# --- Authorize.net (leave blank for test/manual payment mode) ---
# AUTHORIZE_NET_API_LOGIN_ID=
# AUTHORIZE_NET_TRANSACTION_KEY=
# AUTHORIZE_NET_ENVIRONMENT=sandbox  # or "production"
